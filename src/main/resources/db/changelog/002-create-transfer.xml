<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="002" author="dev">
        <createTable tableName="transfer">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" primaryKeyName="PK_transfer" nullable="false"/>
            </column>
            <column name="idempotency_key" type="VARCHAR(64)">
                <constraints nullable="false" unique="true" uniqueConstraintName="UQ_transfer_idem"/>
            </column>
            <column name="from_account_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="FK_transfer_from"
                             references="account(id)"/>
            </column>
            <column name="to_account_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="FK_transfer_to"
                             references="account(id)"/>
            </column>
            <column name="amount" type="DECIMAL(19,4)">
                <constraints nullable="false"/>
            </column>
            <column name="currency" type="VARCHAR(3)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(12)">
                <constraints nullable="false"/>
            </column>
            <column name="request_hash" type="VARCHAR(64)">
                <constraints nullable="false"/>
            </column>
            <column name="failure_reason" type="NVARCHAR(255)"/>
            <column name="created_at" type="DATETIME2(3)" defaultValueComputed="SYSUTCDATETIME()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <sql>
            ALTER TABLE transfer
                ADD CONSTRAINT CK_transfer_amount CHECK (amount &gt; 0);
            ALTER TABLE transfer
                ADD CONSTRAINT CK_transfer_status CHECK (status IN ('PENDING','COMPLETED','FAILED'));
        </sql>
    </changeSet>

</databaseChangeLog>
