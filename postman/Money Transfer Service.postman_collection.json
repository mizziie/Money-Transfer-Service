        {
            "name": "Transfer API",
            "item": [
                {
                    "name": "Create Transfer",
                    "event": [
                        {
                            "listen": "prerequest",
                            "script": {
                                "exec": [
                                    "pm.collectionVariables.set('idempotencyKey', pm.variables.replaceIn('{{$randomUUID}}'));"
                                ],
                                "type": "text/javascript"
                            }
                        },
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 201 or 200', function () {",
                                    "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                                    "});",
                                    "",
                                    "pm.test('Transfer response is valid', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.transferId).to.exist;",
                                    "    pm.expect(jsonData.fromAccountId).to.exist;",
                                    "    pm.expect(jsonData.toAccountId).to.exist;",
                                    "    pm.expect(jsonData.amount).to.exist;",
                                    "    pm.expect(jsonData.status).to.exist;",
                                    "});",
                                    "",
                                    "if (pm.response.code === 201) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.collectionVariables.set('testTransferId', jsonData.transferId);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            },
                            {
                                "key": "Idempotency-Key",
                                "value": "{{idempotencyKey}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"fromAccountId\": {{testAccountId}},\n    \"toAccountId\": {{receiverAccountId}},\n    \"amount\": \"100.00\",\n    \"currency\": \"THB\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/transfers",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "transfers"
                            ]
                        },
                        "description": "Create a new money transfer between account IDs"
                    },
                    "response": []
