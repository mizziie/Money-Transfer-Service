        {
            "name": "Account API",
            "item": [
                {
                    "name": "Create Account",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status code is 201', function () {",
                                    "    pm.response.to.have.status(201);",
                                    "});",
                                    "",
                                    "pm.test('Account created successfully', function () {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.expect(jsonData.id).to.exist;",
                                    "    pm.expect(jsonData.accountNumber).to.exist;",
                                    "    pm.expect(jsonData.ownerName).to.exist;",
                                    "    pm.expect(jsonData.balance).to.exist;",
                                    "    pm.expect(jsonData.currency).to.exist;",
                                    "    pm.expect(jsonData.status).to.exist;",
                                    "});",
                                    "",
                                    "if (pm.response.code === 201) {",
                                    "    var jsonData = pm.response.json();",
                                    "    pm.collectionVariables.set('testAccountNumber', jsonData.accountNumber);",
                                    "    pm.collectionVariables.set('testAccountId', jsonData.id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"ownerName\": \"John Doe\",\n    \"initialBalance\": \"1000.00\",\n    \"currency\": \"THB\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/api/v1/accounts",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "api",
                                "v1",
                                "accounts"
                            ]
                        },
                        "description": "Create a new bank account"
                    },
                    "response": []
